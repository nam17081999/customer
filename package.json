{
  "name": "customer",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx --ignore-pattern .next --ignore-pattern node_modules",
    "lint:fix": "eslint . --ext .js,.jsx --fix --ignore-pattern .next --ignore-pattern node_modules",
    "db:migrations:linked": "supabase migration list --linked",
    "db:seed:orders-demo:linked": "supabase db query --linked -f supabase/seed.sql",
    "db:seed:orders-demo:verify": "supabase db query --linked \"select 'products' as table_name, count(*)::int as count from products where sku like 'HC-TST-%' union all select 'sales_orders', count(*)::int from sales_orders where code like 'DHHC%' union all select 'sales_order_items', count(*)::int from sales_order_items where sales_order_id in (select id from sales_orders where code like 'DHHC%') union all select 'stock_movements', count(*)::int from stock_movements where source_table = 'sales_order_items' and source_id in (select id from sales_order_items where sales_order_id in (select id from sales_orders where code like 'DHHC%'));\"",
    "text:check": "node scripts/check-mojibake.js",
    "text:check:staged": "node scripts/check-mojibake.js --staged",
    "hooks:install": "node scripts/install-git-hooks.js",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.105.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.539.0",
    "maplibre-gl": "^4.7.1",
    "next": "^15.5.18",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-virtuoso": "^4.18.6",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.18",
    "tailwindcss": "^4.3.0",
    "vitest": "^4.1.5"
  }
}
